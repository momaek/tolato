{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskPlanRequest",
  "type": "object",
  "required": ["mode", "target", "input_text"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["ai_agent", "manual_command"]
    },
    "target": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "input_text": {
      "type": "string",
      "minLength": 1
    }
  }
}
