{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskPlanResponse",
  "type": "object",
  "required": ["task_id", "status", "plan"],
  "properties": {
    "task_id": { "type": "string" },
    "status": { "type": "string" },
    "plan": {
      "type": "object",
      "required": ["target_nodes", "summary", "estimated_impact", "risk_level", "requires_approval", "steps"],
      "properties": {
        "target_nodes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary": { "type": "string" },
        "estimated_impact": { "type": "string" },
        "risk_level": { "type": "string" },
        "requires_approval": { "type": "boolean" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["action", "args", "risk", "timeout_sec"],
            "properties": {
              "action": { "type": "string" },
              "args": { "type": "object" },
              "risk": { "type": "string" },
              "timeout_sec": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
