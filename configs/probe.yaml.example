# NodeProbe agent-side config
# Pass to nodeagent via: -probe-config configs/probe.yaml
server_url: "http://localhost:8080/api/v1/probe/report"
auth_token: "agent-dev-token"
node_id: "relay-hk-01"
node_name: "HK Relay"

targets:
  - id: "landing-jp-01"
    name: "JP Landing"
    host: "10.0.1.10"
    ping_count: 10
    tcp_port: 443
    bandwidth_url: "http://10.0.1.10:9090/testfile"

  - id: "landing-us-01"
    name: "US Landing"
    host: "10.0.2.10"
    ping_count: 10
    tcp_port: 443
